"""WebSocket remote server — secure remote MCP access with auth + sessions.

v2.1.0 — CISA Audit Round 2 fixes:
  P0#8: Remote timeout now wraps actual operation (not lambda thread)
  P1: Capability profiles applied to remote sessions
  P1: Per-session action lock for remote input serialization
"""

import asyncio, base64, hmac, json, logging, os, sys, time, uuid
from typing import Any, Dict, Optional

try:
    import websockets
    from websockets.exceptions import ConnectionClosed
except ImportError:
    websockets = None

from .handlers import (
    WindowsAutomationHandler, WindowsAccessibilityHandler, WindowsFileHandler,
)
from .server import _tool_has_capability, get_input_lock, path_policy
from .handlers.windows import initialize_windows_runtime  # share profile check

logger = logging.getLogger(__name__)

DEFAULT_TOKEN_ENV = "COMPUTER_USE_WINDOWS_TOKEN"
HEARTBEAT_INTERVAL = 30
HEARTBEAT_TIMEOUT = 90
MAX_MESSAGE_SIZE = 50 * 1024 * 1024
OPERATION_TIMEOUT = 60.0


class RemoteComputerSession:
    """Isolated session per WebSocket client."""
    def __init__(self):
        self.session_id = uuid.uuid4().hex[:12]
        self.automation = WindowsAutomationHandler()
        self.accessibility = WindowsAccessibilityHandler()
        self.file = WindowsFileHandler()
        self.created_at = time.time()
        self.last_heartbeat = time.time()
        self.input_lock = get_input_lock()  # PS: shared process-wide lock


class RemoteComputerServer:
    """WebSocket server with token auth, session isolation, heartbeat,
    capability enforcement, per-session input serialization."""

    def __init__(self, host: str = "127.0.0.1", port: int = 8765, token: Optional[str] = None):
        self.host = host
        self.port = port
        self.token = token or os.getenv(DEFAULT_TOKEN_ENV)
        if not self.token and host not in {"127.0.0.1", "::1", "localhost"}:
            raise RuntimeError(
                f"A token is required for non-loopback bind. "
                f"Set {DEFAULT_TOKEN_ENV} or pass --token."
            )
        initialize_windows_runtime()  # #5: DPI bootstrap
        self.sessions: Dict[str, RemoteComputerSession] = {}
        logger.info(
            f"Remote server ws://{host}:{port} "
            f"auth={'token' if self.token else 'NONE (loopback)'}"
        )

    async def _authenticate(self, websocket) -> bool:
        if not self.token:
            return True
        try:
            raw = await asyncio.wait_for(websocket.recv(), timeout=5.0)
            msg = json.loads(raw)
            if hmac.compare_digest(msg.get("token", ""), self.token):
                await websocket.send(json.dumps({
                    "status": "ok",
                    "session": msg.get("resume_session", "")
                }))
                return True
            await websocket.send(json.dumps({"status": "error", "error": "Invalid token"}))
            return False
        except (asyncio.TimeoutError, json.JSONDecodeError):
            await websocket.send(json.dumps({
                "status": "error",
                "error": 'Auth required — send {"token":"..."}'
            }))
            return False

    # ── Tool name → capability scope mapping ──────────────────────────

