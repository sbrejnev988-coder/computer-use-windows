        "screenshot_window": "screenshot_window",
        "get_screen_size": "get_screen_size", "get_cursor_position": "get_cursor_position",
        "click": "click", "right_click": "click", "middle_click": "click",
        "double_click": "double_click", "move": "move", "drag": "drag",
        "scroll": "scroll", "mouse_down": "mouse_down", "mouse_up": "mouse_up",
        "type": "type", "press_key": "press_key", "hotkey": "hotkey",
        "key_down": "key_down", "key_up": "key_up",
        "clipboard_get": "clipboard_get", "clipboard_set": "clipboard_set",
        "run_command": "run_command", "launch": "launch",
        "get_current_window": "get_current_window",
        "get_app_windows": "get_app_windows", "list_windows": "list_windows",
        "resize_window": "resize_window", "minimize_window": "minimize_window",
        "maximize_window": "maximize_window", "restore_window": "restore_window",
        "close_window": "close_window", "activate_window": "activate_window",
        "list_processes": "list_processes", "kill_process": "kill_process",
        "registry_read": "registry_read", "registry_write": "registry_write",
        "list_services": "list_services", "service_status": "service_status",
        "service_start": "service_start", "service_stop": "service_stop",
        "service_restart": "service_restart", "system_info": "system_info",
        "get_file_permissions": "get_file_permissions",
        "accessibility_tree": "get_accessibility_tree",
        "find_element": "find_element",
        "get_ui_tree": "get_ui_tree", "find_ui_elements": "find_ui_elements",
        "focus_ui_element": "focus_ui_element",
        "invoke_ui_element": "invoke_ui_element",
        "set_ui_value": "set_ui_value", "toggle_ui_element": "toggle_ui_element",
        "select_ui_element": "select_ui_element",
        "expand_ui_element": "expand_ui_element",
        "scroll_ui_element_into_view": "scroll_ui_element_into_view",
        "wait_for_ui_element": "wait_for_ui_element",
        "file_read": "file_read", "file_write": "file_write",
        "file_read_bytes": "file_read_bytes", "file_write_bytes": "file_write_bytes",
